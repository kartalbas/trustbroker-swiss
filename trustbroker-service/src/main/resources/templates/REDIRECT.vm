##
## Velocity Template for SAML 2 HTTP-POST binding
## Customized for handling cross-domain redirects in response to XMLHttpRequest/fetch calls.
##
## Velocity context may contain the following properties
##
## Binding:
## XTBHttpMethod - String - HTTP method to use (default: POST)
## XTBAdditionalFields - List<org.apache.commons.lang3.tuple.Pair> - additional hidden fields
##
#set ($onLoad="document.forms[0].submit()")
<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8" />
        #parse ( "/templates/add-html-head-content.vm" )
    </head>
    <body onload="$onLoad">
		<noscript>
			<p>
				<strong>Note:</strong> Since your browser does not support JavaScript,
				you must press the Continue button once to proceed.
			</p>
		</noscript>
		<form name="saml.result" action="${action}" method="#if($XTBHttpMethod)${XTBHttpMethod}#{else}POST#end">
			<div>
				#foreach($field in $XTBAdditionalFields)
					<input type="hidden" name="${field.name}" value="$!{field.value}"/>
				#end
			</div>
			<noscript>
				<div>
					<input type="submit" value="Continue"/>
				</div>
			</noscript>
		</form>
        #parse ( "/templates/add-html-body-content.vm" )
    </body>
</html>
